{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/image.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/:path*",  "destination": "/api/:path*" },
    { "source": "/games",       "destination": "/games.html" },
    { "source": "/gallery",     "destination": "/gallery.html" },
    { "source": "/videos",      "destination": "/videos.html" },
    { "source": "/story",       "destination": "/story.html" },
    { "source": "/puzzle",      "destination": "/puzzle.html" },
    { "source": "/carousel",    "destination": "/carousel.html" },
    { "source": "/",            "destination": "/index.html" }
  ]
}
